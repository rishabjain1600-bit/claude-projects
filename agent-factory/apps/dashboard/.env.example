# Copy this file to .env.local and fill in your values
# Get an Anthropic API key at https://console.anthropic.com

ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Model toggle — defaults to Haiku (fast, cheap, good for testing)
# Uncomment to use Sonnet for demos or when response quality matters
# AI_MODEL=sonnet

# Optional: Supabase (not required for local demo — uses in-memory store)
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
